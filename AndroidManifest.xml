<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="コード進行管理"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Chordprogress">
        <activity android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".RegisterActivity"
            android:screenOrientation="landscape" />
        <activity android:name=".ManageActivity"
            android:screenOrientation="landscape" />
        <activity android:name=".SongEditorActivity"
            android:screenOrientation="landscape" />
        <activity android:name=".ChordSelectActivity"
            android:screenOrientation="landscape" />
        <activity android:name=".SongListActivity"
            android:screenOrientation="landscape" />
        <activity android:name=".SongDetailActivity"
            android:screenOrientation="landscape" />
    </application>

</manifest>