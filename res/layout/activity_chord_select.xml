<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- ヘッダー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#12122a"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎸 コード選択"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- ♯トグル -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♯"
            android:textColor="#aaaacc"
            android:textSize="14sp"
            android:layout_marginEnd="4dp" />

        <Switch
            android:id="@+id/sharp_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="キャンセル"
            android:textSize="11sp"
            android:backgroundTint="#dc8c3c"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="保存する"
            android:textSize="11sp"
            android:backgroundTint="#7048e8" />

    </LinearLayout>

    <!-- メインコンテンツ（左右分割） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 左：コード選択パネル -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- タブ（2つ） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="#12122a"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tab_diatonic"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="ダイアトニック"
                    android:textColor="#ffffff"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tab_category"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="カテゴリ"
                    android:textColor="#888899"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ダイアトニックパネル -->
            <ScrollView
                android:id="@+id/scroll_diatonic"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/diatonic_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />

            </ScrollView>

            <!-- カテゴリパネル -->
            <ScrollView
                android:id="@+id/scroll_category"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/category_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp" />

            </ScrollView>

        </LinearLayout>

        <!-- 右：選択済みコード表示 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#12122a"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="選択済みコード進行"
                android:textColor="#aaaacc"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/selected_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="コードを選択してください"
                android:textColor="#555577"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/selected_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp" />

            </HorizontalScrollView>

            <Button
                android:id="@+id/btn_undo"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="← 1つ戻す"
                android:textSize="12sp"
                android:backgroundTint="#4a6fa5"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="全クリア"
                android:textSize="12sp"
                android:backgroundTint="#c83c3c" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
