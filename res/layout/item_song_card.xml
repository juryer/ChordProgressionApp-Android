<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#252545"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- 左ライン -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#7048e8"
            android:layout_marginEnd="12dp" />

        <!-- 情報 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/text_song_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#7048e8"
                    android:textSize="12sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/text_song_sections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#aaaacc"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_song_updated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#555577"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- ボタン -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <Button
                android:id="@+id/btn_song_edit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="編集"
                android:textSize="12sp"
                android:backgroundTint="#7048e8"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_song_delete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="削除"
                android:textSize="12sp"
                android:backgroundTint="#c83c3c" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
