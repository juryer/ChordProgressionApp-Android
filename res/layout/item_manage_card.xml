<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardBackgroundColor="#252545"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- 左ライン -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#dc8c3c"
            android:layout_marginEnd="12dp" />

        <!-- 情報 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_chords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8888ff"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/text_memo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/text_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#aaaacc"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- ボタン群 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <Button
                android:id="@+id/btn_up"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="▲"
                android:textSize="11sp"
                android:backgroundTint="#4a6fa5"
                android:layout_marginEnd="4dp"
                android:padding="0dp" />

            <Button
                android:id="@+id/btn_down"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="▼"
                android:textSize="11sp"
                android:backgroundTint="#4a6fa5"
                android:layout_marginEnd="4dp"
                android:padding="0dp" />

            <Button
                android:id="@+id/btn_edit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="編集"
                android:textSize="12sp"
                android:backgroundTint="#7048e8"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="削除"
                android:textSize="12sp"
                android:backgroundTint="#c83c3c" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
